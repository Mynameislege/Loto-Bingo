# Copy to .env and fill in values

# Database (PostgreSQL + PostGIS on Railway)
DATABASE_URL="postgresql://user:password@localhost:5432/loto_seniors?schema=public"

# Redis (Railway)
REDIS_URL="redis://localhost:6379"

# Firebase Admin SDK
# Set GOOGLE_APPLICATION_CREDENTIALS to path of your service account JSON
# OR set the JSON content inline:
GOOGLE_APPLICATION_CREDENTIALS="/path/to/firebase-service-account.json"

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# CORS — mobile Expo dev server + sponsor portal
ALLOWED_ORIGINS="http://localhost:8081,http://localhost:5173"

# Cloudflare R2 (for audio files — add when needed)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=loto-seniors-assets
# R2_PUBLIC_URL=https://assets.lotoseniors.fr
